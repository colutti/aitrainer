{
  "node_name": "training_specialist",
  "enabled": true,
  "model_provider": "openrouter",
  "model_name": "google/gemini-3.1-flash-lite-preview",
  "temperature": 0.1,
  "max_tokens": 4096,
  "tool_policy": "restricted",
  "tool_names": [
    "save_workout",
    "get_workouts",
    "save_body_composition",
    "get_body_composition",
    "get_plan",
    "get_user_goal",
    "get_metabolism_data"
  ],
  "prompt_file": "backend/src/services/agents/config/prompts/training_specialist.md",
  "response_format": "json",
  "version": "v3",
  "context_blocks": [
    "request",
    "user_profile",
    "active_plan",
    "metabolism",
    "history_summary_neutral",
    "conversation_state"
  ],
  "peer_inputs": [
    "nutrition_specialist"
  ],
  "persona_mode": "none",
  "output_contract": "json(action_type,action_status,domain_status,technical_summary,missing_inputs,plan_signal,training_proposal,proposal_status,change_request,pending_action,memory_candidates,event_candidates)"
}
