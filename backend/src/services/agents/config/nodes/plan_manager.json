{
  "node_name": "plan_manager",
  "enabled": true,
  "model_provider": "openrouter",
  "model_name": "openai/gpt-4o-mini",
  "temperature": 0.2,
  "max_tokens": 4096,
  "tool_policy": "restricted",
  "tool_names": [],
  "prompt_file": "backend/src/services/agents/config/prompts/plan_manager.md",
  "response_format": "text",
  "version": "v1",
  "context_blocks": ["request", "active_plan", "training_analysis", "nutrition_analysis", "context_summary"],
  "peer_inputs": ["training_specialist", "nutrition_specialist"],
  "persona_mode": "none",
  "output_contract": "json(needs_revision,reason,plan_candidate)"
}
