{
  "node_name": "prompt_security",
  "enabled": true,
  "model_provider": "openrouter",
  "model_name": "google/gemini-2.5-flash-lite",
  "temperature": 0.0,
  "max_tokens": 1024,
  "tool_policy": "restricted",
  "tool_names": [],
  "prompt_file": "backend/src/services/agents/config/prompts/prompt_security.md",
  "response_format": {
    "type": "json_schema",
    "json_schema": {
      "name": "prompt_security_output",
      "strict": true,
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "status": {"type": "string"},
          "reason": {"type": "string"},
          "sanitized": {"type": "string"}
        },
        "required": ["status", "reason", "sanitized"]
      }
    }
  },
  "version": "v2",
  "context_blocks": [
    "request"
  ],
  "peer_inputs": [],
  "persona_mode": "none",
  "output_contract": "json(status,reason,sanitized)",
  "provider_sort": "throughput"
}
