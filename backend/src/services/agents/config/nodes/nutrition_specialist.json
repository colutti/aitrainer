{
  "node_name": "nutrition_specialist",
  "enabled": true,
  "model_provider": "openrouter",
  "model_name": "google/gemini-3.1-flash-lite-preview",
  "temperature": 0.1,
  "max_tokens": 4096,
  "tool_policy": "restricted",
  "tool_names": [
    "save_daily_nutrition",
    "get_workouts",
    "get_nutrition",
    "sync_nutrition_text",
    "get_metabolism_data",
    "get_user_goal",
    "update_tdee_params"
  ],
  "prompt_file": "backend/src/services/agents/config/prompts/nutrition_specialist.md",
  "response_format": "json",
  "version": "v1",
  "context_blocks": [
    "request",
    "user_profile",
    "active_plan",
    "metabolism",
    "history_summary_neutral",
    "training_analysis"
  ],
  "peer_inputs": [
    "training_specialist"
  ],
  "persona_mode": "none",
  "output_contract": "json(action_type,action_status,domain_status,technical_summary,missing_inputs,handoff_target,handoff_reason,pending_action,plan_signal,memory_candidates,event_candidates)"
}