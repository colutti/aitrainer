{
  "node_name": "nutrition_specialist",
  "enabled": true,
  "model_provider": "openrouter",
  "model_name": "google/gemini-3-flash-preview",
  "temperature": 0.2,
  "max_tokens": 6144,
  "reasoning": {
    "effort": "low",
    "exclude": true
  },
  "parallel_tool_calls": false,
  "tool_policy": "restricted",
  "tool_names": [
    "save_daily_nutrition",
    "get_workouts",
    "get_nutrition",
    "sync_nutrition_text",
    "get_metabolism_data",
    "get_user_goal",
    "update_tdee_params"
  ],
  "prompt_file": "backend/src/services/agents/config/prompts/nutrition_specialist.md",
  "response_format": {
    "type": "json_schema",
    "json_schema": {
      "name": "nutrition_specialist_output",
      "strict": true,
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "action_type": {"type": "string"},
          "action_status": {"type": "string", "enum": ["executed", "failed", "needs_user_input", "no_action_needed"]},
          "domain_status": {"type": "string"},
          "public_message": {"type": "string"},
          "internal_analysis": {"type": "string"},
          "operation_result": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "attempted": {"type": "boolean"},
              "succeeded": {"type": "boolean"},
              "tool_name": {"type": "string"},
              "error_code": {"type": "string"},
              "evidence": {"type": "string"}
            },
            "required": ["attempted", "succeeded", "tool_name", "error_code", "evidence"]
          },
          "missing_inputs": {"type": "array", "items": {"type": "string"}},
          "plan_signal": {"type": "string"},
          "pending_action": {
            "type": "object",
            "properties": {
              "kind": {"type": "string"},
              "status": {"type": "string"},
              "missing_slots": {"type": "array", "items": {"type": "string"}}
            },
            "required": ["kind", "status", "missing_slots"],
            "additionalProperties": false
          },
          "memory_candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "memory_action": {"type": "string"},
                "memory_content": {"type": "string"},
                "memory_category": {"type": "string"}
              },
              "required": ["memory_action", "memory_content", "memory_category"],
              "additionalProperties": false
            }
          },
          "event_candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "event_action": {"type": "string"},
                "event_title": {"type": "string"},
                "event_date": {"type": "string"},
                "recurrence": {"type": "string"}
              },
              "required": ["event_action", "event_title", "event_date"],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "action_type",
          "action_status",
          "domain_status",
          "public_message",
          "internal_analysis",
          "operation_result",
          "missing_inputs",
          "plan_signal",
          "pending_action",
          "memory_candidates",
          "event_candidates"
        ]
      }
    }
  },
  "version": "v3",
  "context_blocks": [
    "request",
    "user_profile",
    "active_plan",
    "metabolism",
    "history_summary_neutral",
    "training_analysis",
    "conversation_state"
  ],
  "peer_inputs": [
    "training_specialist"
  ],
  "persona_mode": "none",
  "output_contract": "json(action_type,action_status,domain_status,public_message,internal_analysis,missing_inputs,plan_signal,operation_result,pending_action,memory_candidates,event_candidates)",
  "provider_sort": "throughput"
}
