{
  "node_name": "memory_hub",
  "enabled": true,
  "model_provider": "openrouter",
  "model_name": "google/gemini-3.1-flash-lite-preview",
  "temperature": 0.0,
  "max_tokens": 2048,
  "tool_policy": "restricted",
  "tool_names": [
    "list_events",
    "create_event",
    "update_event",
    "delete_event",
    "search_memory",
    "save_memory",
    "update_memory",
    "delete_memory"
  ],
  "prompt_file": "backend/src/services/agents/config/prompts/memory_hub.md",
  "response_format": {
    "type": "json_schema",
    "json_schema": {
      "name": "memory_hub_output",
      "strict": true,
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "event_action": {"type": "string"},
          "event_title": {"type": "string"},
          "event_date": {"type": "string"},
          "event_id": {"type": "string"},
          "event_recurrence": {"type": "string"},
          "recurrence": {"type": "string"},
          "memory_action": {"type": "string"},
          "memory_content": {"type": "string"},
          "memory_id": {"type": "string"},
          "memory_category": {"type": "string"},
          "summary_update": {"type": "string"},
          "reason": {"type": "string"}
        },
        "required": ["reason"]
      }
    }
  },
  "version": "v3",
  "context_blocks": [
    "request",
    "specialist_results",
    "persistence_candidates",
    "conversation_summary"
  ],
  "peer_inputs": [],
  "persona_mode": "none",
  "output_contract": "json(event_action,memory_action,summary_update,reason,...)",
  "provider_sort": "throughput"
}
