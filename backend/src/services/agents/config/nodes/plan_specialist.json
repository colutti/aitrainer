{
  "node_name": "plan_specialist",
  "enabled": true,
  "model_provider": "openrouter",
  "model_name": "openai/gpt-oss-120b",
  "temperature": 0.2,
  "max_tokens": 4096,
  "tool_policy": "restricted",
  "tool_names": [
    "get_plan",
    "upsert_plan",
    "plan_help",
    "get_user_goal",
    "update_user_goal",
    "get_metabolism_data"
  ],
  "prompt_file": "backend/src/services/agents/config/prompts/plan_specialist.md",
  "response_format": "json",
  "version": "v1",
  "provider_sort": "throughput",
  "context_blocks": [
    "request",
    "current_date",
    "active_plan",
    "training_analysis",
    "nutrition_analysis",
    "metabolism",
    "history_summary_neutral"
  ],
  "peer_inputs": [
    "training_specialist",
    "nutrition_specialist"
  ],
  "persona_mode": "none",
  "output_contract": "json(plan_status,reason,technical_summary,needs_revision,plan_candidate,memory_candidates,event_candidates)"
}