{
  "node_name": "plan_specialist",
  "enabled": true,
  "model_provider": "openrouter",
  "model_name": "openai/gpt-oss-120b",
  "temperature": 0.1,
  "max_tokens": 6144,
  "reasoning": {
    "effort": "low",
    "exclude": true
  },
  "parallel_tool_calls": false,
  "tool_policy": "restricted",
  "tool_names": [
    "get_plan",
    "upsert_plan",
    "plan_help",
    "get_user_goal",
    "update_user_goal",
    "get_metabolism_data"
  ],
  "prompt_file": "backend/src/services/agents/config/prompts/plan_specialist.md",
  "response_format": {
    "type": "json_schema",
    "json_schema": {
      "name": "plan_specialist_output",
      "strict": true,
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "plan_status": { "type": "string" },
          "action_status": { "type": "string", "enum": ["executed", "failed", "needs_user_input", "no_action_needed"] },
          "reason": { "type": "string" },
          "public_message": { "type": "string" },
          "internal_analysis": { "type": "string" },
          "needs_revision": { "type": "boolean" },
          "plan_candidate": { "type": "string" },
          "pending_slots": { "type": "array", "items": { "type": "string" } },
          "resolved_slots": { "type": "array", "items": { "type": "string" } },
          "operation_result": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "attempted": { "type": "boolean" },
              "succeeded": { "type": "boolean" },
              "tool_name": { "type": "string" },
              "error_code": { "type": "string" },
              "evidence": { "type": "string" }
            },
            "required": ["attempted", "succeeded", "tool_name", "error_code", "evidence"]
          },
          "pending_action": {
            "type": "object",
            "properties": {
              "kind": { "type": "string" },
              "status": { "type": "string" },
              "missing_slots": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": ["kind", "status", "missing_slots"],
            "additionalProperties": false
          },
          "memory_candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "memory_action": { "type": "string" },
                "memory_content": { "type": "string" },
                "memory_category": { "type": "string" }
              },
              "required": [
                "memory_action",
                "memory_content",
                "memory_category"
              ],
              "additionalProperties": false
            }
          },
          "event_candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "event_action": { "type": "string" },
                "event_title": { "type": "string" },
                "event_date": { "type": "string" },
                "recurrence": { "type": "string" }
              },
              "required": ["event_action", "event_title", "event_date"],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "plan_status",
          "action_status",
          "reason",
          "public_message",
          "internal_analysis",
          "needs_revision",
          "plan_candidate",
          "pending_slots",
          "resolved_slots",
          "operation_result",
          "pending_action",
          "memory_candidates",
          "event_candidates"
        ]
      }
    }
  },
  "version": "v3",
  "provider_sort": "throughput",
  "context_blocks": [
    "request",
    "current_date",
    "active_plan",
    "training_analysis",
    "nutrition_analysis",
    "metabolism",
    "history_summary_neutral",
    "plan_lifecycle",
    "conversation_state"
  ],
  "peer_inputs": ["training_specialist", "nutrition_specialist"],
  "persona_mode": "none",
  "output_contract": "json(plan_status,action_status,reason,public_message,internal_analysis,needs_revision,plan_candidate,pending_slots,resolved_slots,operation_result,pending_action,memory_candidates,event_candidates)"
}
